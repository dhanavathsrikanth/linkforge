{
  "name": "linkforge-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the LinkForge API — link shorting, analytics, and QR codes.",
  "license": "MIT",
  "author": "LinkForge",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "linkforge",
    "link-shortener",
    "analytics",
    "qr-code",
    "sdk"
  ]
}
